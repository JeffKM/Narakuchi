{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/favicon.ico", "destination": "/index.icon.png" }
  ],
  "headers": [
    {
      "source": "/index.service.worker.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    },
    {
      "source": "/index.manifest.json",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    }
  ]
}
