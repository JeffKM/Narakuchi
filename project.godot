; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="나라쿠치"
config/description="나라카 컨셉카페 팬게임 — 도트 데일리 교감·수집 게임"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[audio]

; mix_rate=0 → AudioContext를 디바이스 기본 샘플레이트로 생성.
; iOS Safari 하드웨어는 48kHz라 기본값 44100을 강제하면 무음이 되는 경우가 많다.
; (iOS 웹 무음 양대 원인 ①: 샘플레이트 불일치. ②=AudioContext resume은 HTML unlock 스크립트로 처리, export_presets.cfg 참조.)
driver/mix_rate=0
driver/mix_rate.web=0

[autoload]

SaveManager="*res://scripts/systems/save_manager.gd"
Sfx="*res://scripts/systems/sfx.gd"

[display]

window/size/viewport_width=635
window/size/viewport_height=877
window/size/window_width_override=953
window/size/window_height_override=1316
window/stretch/mode="canvas_items"
window/per_pixel_transparency/allowed=true
window/handheld/orientation=1

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
